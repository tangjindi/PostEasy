function _t(s) {
  if (state.lang === 'en' && I18N[s]) return I18N[s];
  return s;
}

// ===== HELPERS =====
function escHtml(s) { if (!s) return ''; return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;'); }
function escAttr(s) { return String(s).replace(/&/g,'&amp;').replace(/"/g,'&quot;').replace(/'/g,'&#39;'); }
function escapeQuotes(s) { return String(s).replace(/'/g,"\\'"); }
function simpleType(javaType) { return (javaType||'').split('.').pop().replace(/\[\]$/,''); }
function isSimpleDateType(t) { return t==='Date'||t==='LocalDate'||t==='LocalDateTime'||t==='LocalTime'||t==='ZonedDateTime'||t==='Instant'||t==='Timestamp'; }
function isDateTimeType(t) { return t==='Date'||t==='LocalDateTime'||t==='ZonedDateTime'||t==='Instant'||t==='Timestamp'; }
function isSimpleNumberType(t) { return t==='Integer'||t==='int'||t==='Long'||t==='long'||t==='Double'||t==='double'||t==='Float'||t==='float'||t==='BigDecimal'; }
function httpColor(method) {
  var colors = {GET:'#22c55e',POST:'#3b82f6',PUT:'#f97316',DELETE:'#ef4444',PATCH:'#a855f7',HEAD:'#6b7280',OPTIONS:'#6b7280',ALL:'#6b7280'};
  return colors[method] || '#6b7280';
}
// Flatten nested object to dot-notation keys for form-encoded/query params
function flattenObject(obj, prefix) {
  var result = {};
  prefix = prefix || '';
  for (var key in obj) {
    if (!obj.hasOwnProperty(key)) continue;
    var val = obj[key];
    var fullKey = prefix ? (prefix + '.' + key) : key;
    if (val !== null && typeof val === 'object' && !Array.isArray(val)) {
      var nested = flattenObject(val, fullKey);
      for (var nk in nested) {
        if (nested.hasOwnProperty(nk)) result[nk] = nested[nk];
      }
    } else {
      result[fullKey] = val;
    }
  }
  return result;
}

function formatJson(obj) { try { return JSON.stringify(obj, null, 2); } catch(e){ return String(obj); } }
function toggleSection(titleEl) {
  titleEl.classList.toggle('collapsed');
  var body = titleEl.nextElementSibling;
  if (body) body.classList.toggle('hidden');
}

// ===== RECURSIVE FIELD TREE RENDERING =====
var _fieldRowId = 0;
function renderFieldRow(field, depth, editKey) {
  _fieldRowId++;
  var rid = 'frow' + _fieldRowId;
  var hasKids = field.children && field.children.length > 0;
  var html = '';
  html += '<div class="field-row depth-' + depth + (hasKids ? ' has-children' : '') + '"' + (hasKids ? ' onclick="toggleFieldKids(\'' + rid + '\')"' : '') + '>';
  // Name with expand arrow
  html += '<span class="field-col-name" style="font-family:var(--mono);">';
  if (hasKids) {
    html += '<span class="field-expand" id="' + rid + '-arrow">▶</span>';
  } else {
    html += '<span class="field-expand" style="visibility:hidden;">▶</span>';
  }
  html += escHtml(field.name);
  // Tags
  if (field.circularRef) html += '<span class="field-tag circular" title="' + _t('循环引用') + ': ' + escHtml(field.circularRef) + '">↻' + escHtml(field.circularRef) + '</span>';
  if (field.truncated) html += '<span class="field-tag truncated" title="' + _t('超过最大深度，已截断') + '">' + _t('截断') + '</span>';
  if (field.polymorphic) html += '<span class="field-tag poly" title="' + _t('多态类型') + '">' + _t('多态') + '</span>';
  html += '</span>';
  // Type
  html += '<span class="field-col-type" style="font-family:var(--mono);font-size:11px;color:var(--text2);">' + escHtml(field.javaType) + '</span>';
  // Description (editable)
  html += '<span class="field-col-desc">';
  html += '<span class="editable-label" contenteditable="true" data-edit="' + editKey + '" onblur="onEdit(this)" onclick="event.stopPropagation();">' + escHtml(getEdit(editKey, field.description || '')) + '</span>';
  html += '</span>';
  html += '</div>';
  // Children container
  if (hasKids) {
    html += '<div id="' + rid + '-kids" style="display:none;">';
    for (var k = 0; k < field.children.length; k++) {
      html += renderFieldRow(field.children[k], depth + 1, editKey + '_c' + k);
    }
    html += '</div>';
  }
  return html;
}

function toggleFieldKids(rid) {
  var kids = document.getElementById(rid + '-kids');
  var arrow = document.getElementById(rid + '-arrow');
  if (kids) {
    var show = kids.style.display === 'none';
    kids.style.display = show ? 'block' : 'none';
    if (arrow) {
      if (show) arrow.classList.add('open');
      else arrow.classList.remove('open');
    }
  }
}

// ===== BODY FIELD ROW WITH INLINE INPUT =====
function renderBodyFieldRow(field, depth, pathIdx, ctrlIdx, apiIdx) {
  _fieldRowId++;
  var rid = 'bfrow' + _fieldRowId;
  var hasKids = field.children && field.children.length > 0;
  var bodyPath = pathIdx; // e.g. "0" or "0_2_1" for nested
  var inputId = 'bfinput_' + ctrlIdx + '_' + apiIdx + '_' + bodyPath;
  // Restore saved value
  var paramKey = 'bodyfield_' + ctrlIdx + '_' + apiIdx + '_' + bodyPath;
  var savedVal = state.paramValues[paramKey] !== undefined ? state.paramValues[paramKey] : '';
  // Determine input type
  var st = simpleType(field.javaType);
  var inputType = 'text';
  var isList = st.indexOf('List') >= 0 || st.indexOf('Set') >= 0 || st.indexOf('Collection') >= 0 || field.javaType.indexOf('[]') >= 0;
  var isNumber = isSimpleNumberType(st);
  var isBool = st === 'Boolean' || st === 'boolean';
  var isDate = isSimpleDateType(st);
  var isDateTime = isDateTimeType(st);
  if (isNumber) inputType = 'number';

  var html = '';
  html += '<div class="field-row depth-' + depth + (hasKids ? ' has-children' : '') + '"' + (hasKids ? ' onclick="toggleFieldKids(\'' + rid + '\')"' : '') + '>';
  // Name with expand arrow
  html += '<span class="field-col-name" style="font-family:var(--mono);">';
  if (hasKids) {
    html += '<span class="field-expand" id="' + rid + '-arrow">▶</span>';
  } else {
    html += '<span class="field-expand" style="visibility:hidden;">▶</span>';
  }
  html += escHtml(field.name);
  if (field.circularRef) html += '<span class="field-tag circular" title="' + _t('循环引用') + '">↻' + escHtml(field.circularRef) + '</span>';
  if (field.truncated) html += '<span class="field-tag truncated">' + _t('截断') + '</span>';
  html += '</span>';
  // Type
  html += '<span class="field-col-type" style="font-family:var(--mono);font-size:11px;color:var(--text2);">' + escHtml(field.javaType) + '</span>';
  // Description — editable like other param/response descriptions
  html += '<span class="field-col-desc">';
  html += '<span class="editable-label" contenteditable="true" data-edit="bodydesc_' + ctrlIdx + '_' + apiIdx + '_' + bodyPath + '" style="font-size:11px;">' + escHtml(getEdit('bodydesc_' + ctrlIdx + '_' + apiIdx + '_' + bodyPath, field.description || '')) + '</span>';
  html += '</span>';
  // Value input
  html += '<span class="field-col-val" onclick="event.stopPropagation();">';
  if (!hasKids) {
    if (isBool) {
      html += '<select data-bodypath="' + bodyPath + '" data-ctrl="' + ctrlIdx + '" data-api="' + apiIdx + '" onchange="onBodyFieldChange(this)" style="font-size:11px;padding:2px 4px;border:1px solid var(--border);border-radius:3px;background:var(--bg);color:var(--text);width:80px;">';
      html += '<option value="">--</option>';
      html += '<option value="true"' + (savedVal === 'true' ? ' selected' : '') + '>true</option>';
      html += '<option value="false"' + (savedVal === 'false' ? ' selected' : '') + '>false</option>';
      html += '</select>';
    } else if (isDateTime) {
      html += '<input type="datetime-local" step="1" data-bodypath="' + bodyPath + '" data-ctrl="' + ctrlIdx + '" data-api="' + apiIdx + '" value="' + escHtml(savedVal) + '" onchange="onBodyFieldChange(this)" oninput="onBodyFieldChange(this)" style="font-size:11px;padding:2px 6px;border:1px solid var(--border);border-radius:3px;background:var(--bg);color:var(--text);width:100%;min-width:180px;">';
    } else if (isDate) {
      // LocalDate → date, LocalTime → time
      var dateType = st === 'LocalDate' ? 'date' : 'time';
      html += '<input type="' + dateType + '" step="1" data-bodypath="' + bodyPath + '" data-ctrl="' + ctrlIdx + '" data-api="' + apiIdx + '" value="' + escHtml(savedVal) + '" onchange="onBodyFieldChange(this)" oninput="onBodyFieldChange(this)" style="font-size:11px;padding:2px 6px;border:1px solid var(--border);border-radius:3px;background:var(--bg);color:var(--text);width:100%;min-width:110px;">';
    } else {
      var ph = isNumber ? '0' : (isList ? _t('逗号分隔, 如: a,b,c') : '');
      html += '<input type="' + inputType + '" data-bodypath="' + bodyPath + '" data-ctrl="' + ctrlIdx + '" data-api="' + apiIdx + '" data-islist="' + (isList ? '1' : '0') + '" value="' + escHtml(savedVal) + '" onchange="onBodyFieldChange(this)" oninput="onBodyFieldChange(this)" placeholder="' + ph + '" title="' + (isList ? _t('多个值请用英文逗号分隔') : '') + '" style="font-size:11px;padding:2px 6px;border:1px solid var(--border);border-radius:3px;background:var(--bg);color:var(--text);width:100%;min-width:80px;">';
    }
  }
  html += '</span>';
  html += '</div>';
  // Children
  if (hasKids) {
    html += '<div id="' + rid + '-kids" style="display:none;">';
    for (var k = 0; k < field.children.length; k++) {
      html += renderBodyFieldRow(field.children[k], depth + 1, bodyPath + '_' + k, ctrlIdx, apiIdx);
    }
    html += '</div>';
  }
  return html;
}

function onBodyFieldChange(el) {
  var ctrlIdx = el.getAttribute('data-ctrl');
  var apiIdx = el.getAttribute('data-api');
  var bodyPath = el.getAttribute('data-bodypath');
  var key = 'bodyfield_' + ctrlIdx + '_' + apiIdx + '_' + bodyPath;
  state.paramValues[key] = el.value;
  persist();
}

// Build a nested JSON object from the inline field inputs
function buildBodyFromFields(ctrlIdx, apiIdx) {
  var result = {};
  var prefix = 'bodyfield_' + ctrlIdx + '_' + apiIdx + '_';
  var keys = Object.keys(state.paramValues);
  // Sort by path depth to process parents before children
  var relevant = [];
  for (var i = 0; i < keys.length; i++) {
    if (keys[i].indexOf(prefix) === 0) {
      relevant.push({key: keys[i], path: keys[i].substring(prefix.length)});
    }
  }
  if (relevant.length === 0) return null;

  // Group by top-level index
  var topValues = {};
  for (var j = 0; j < relevant.length; j++) {
    var r = relevant[j];
    var val = state.paramValues[r.key];
    if (val === undefined || val === '') continue;
    var pathParts = r.path.split('_');
    // pathParts[0] is the top-level field index
    var firstIdx = pathParts[0];
    var restPath = pathParts.slice(1).join('_');
    if (!topValues[firstIdx]) topValues[firstIdx] = {};
    if (restPath) {
      setNestedByPath(topValues[firstIdx], restPath, val);
    }
  }

  return result;
}

// Actually, let me use a simpler approach: walk the DOM
function buildBodyFromDOM(ctrlIdx, apiIdx) {
  var tree = document.querySelector('.body-field-tree[data-body-ctrl="' + ctrlIdx + '"][data-body-api="' + apiIdx + '"]');
  if (!tree) return null;
  var inputs = tree.querySelectorAll('[data-bodypath]');
  if (inputs.length === 0) return null;

  var result = {};
  for (var i = 0; i < inputs.length; i++) {
    var inp = inputs[i];
    var val = inp.value;
    if (val === '' || val === undefined) continue;
    var path = inp.getAttribute('data-bodypath');
    // Convert type if needed
    if (inp.type === 'number') {
      val = val.indexOf('.') >= 0 ? parseFloat(val) : parseInt(val, 10);
    } else if (inp.tagName === 'SELECT') {
      if (val === 'true') val = true;
      else if (val === 'false') val = false;
    }
    setNestedByPath(result, path, val);
  }
  return Object.keys(result).length > 0 ? result : null;
}

// Set a nested value by path like "0_2_1" (indices into children arrays)
// Need to resolve indices to actual field names and types
function buildBodyObject(ctrlIdx, apiIdx, locationFilter) {
  var ctrl = state.data.controllers[ctrlIdx];
  var api = ctrl.methods[apiIdx];
  if (!locationFilter) locationFilter = 'body';
  var complexParams = api.parameters.filter(function(p){return p.location===locationFilter && p.children && p.children.length > 0;});
  if (complexParams.length === 0) return null;

  // Walk the field tree and collect values
  function walkFields(fields, pathPrefix) {
    var obj = {};
    var hasValue = false;
    for (var i = 0; i < fields.length; i++) {
      var f = fields[i];
      var childPath = pathPrefix !== '' ? (pathPrefix + '_' + i) : ('' + i);
      var paramKey = 'bodyfield_' + ctrlIdx + '_' + apiIdx + '_' + childPath;
      if (f.children && f.children.length > 0) {
        var childObj = walkFields(f.children, childPath);
        if (childObj) {
          obj[f.name] = childObj;
          hasValue = true;
        }
      } else {
        var val = state.paramValues[paramKey];
        if (val !== undefined && val !== '') {
          // Check if this field is a List/Set/Collection (comma-separated)
          var isListType = f.javaType.indexOf('List<') >= 0 || f.javaType.indexOf('Set<') >= 0 || f.javaType.indexOf('Collection<') >= 0 || f.javaType.indexOf('[]') >= 0;
          if (isListType && val.indexOf(',') >= 0) {
            var parts = val.split(',');
            var arr = [];
            for (var li = 0; li < parts.length; li++) {
              var item = parts[li].trim();
              if (item === '') continue;
              // Type coercion for list items
              var innerType = f.javaType.replace(/^(?:List|Set|Collection)<(.+)>$/, '$1').replace(/\[\]$/, '');
              var innerSt = simpleType(innerType);
              if (isSimpleNumberType(innerSt)) {
                item = innerSt.indexOf('Double')>=0||innerSt.indexOf('Float')>=0||innerSt==='BigDecimal' ? parseFloat(item) : parseInt(item, 10);
              } else if (innerSt === 'Boolean' || innerSt === 'boolean') {
                item = item === 'true';
              }
              arr.push(item);
            }
            val = arr;
          } else if (isListType && val.indexOf(',') < 0) {
            // Single value in a List field → wrap in array
            val = [val];
            // Type coercion for single item
            var sit = simpleType(f.javaType.replace(/^(?:List|Set|Collection)<(.+)>$/, '$1').replace(/\[\]$/, ''));
            if (isSimpleNumberType(sit)) {
              val = [sit.indexOf('Double')>=0||sit.indexOf('Float')>=0||sit==='BigDecimal' ? parseFloat(val[0]) : parseInt(val[0], 10)];
            } else if (sit === 'Boolean' || sit === 'boolean') {
              val = [val[0] === 'true'];
            }
          } else {
            // Type coercion for scalar values
            var sf = simpleType(f.javaType);
            if (isSimpleNumberType(sf)) {
              val = sf.indexOf('Double')>=0||sf.indexOf('Float')>=0||sf==='BigDecimal' ? parseFloat(val) : parseInt(val, 10);
            } else if (sf === 'Boolean' || sf === 'boolean') {
              val = val === 'true';
            }
          }
          obj[f.name] = val;
          hasValue = true;
        }
      }
    }
    return hasValue ? obj : null;
  }

  // For each body parameter, walk its children
  var bodyObj = {};
  var bpIdx = 0;
  for (var bp = 0; bp < api.parameters.length; bp++) {
    if (api.parameters[bp].location !== locationFilter) continue;
    var children = api.parameters[bp].children;
    if (children && children.length > 0) {
      var obj = walkFields(children, '');
      if (obj) {
        // Return the object directly without wrapping in param name
        return obj;
      }
    }
    bpIdx++;
  }
  return Object.keys(bodyObj).length > 0 ? bodyObj : null;
}

function fillBodyExample(ctrlIdx, apiIdx) {
  var ctrl = state.data.controllers[ctrlIdx];
  var api = ctrl.methods[apiIdx];

  function walkAndFill(fields, pathPrefix) {
    for (var i = 0; i < fields.length; i++) {
      var f = fields[i];
      var childPath = pathPrefix !== '' ? (pathPrefix + '_' + i) : ('' + i);
      var paramKey = 'bodyfield_' + ctrlIdx + '_' + apiIdx + '_' + childPath;
      if (f.children && f.children.length > 0) {
        walkAndFill(f.children, childPath);
      } else {
        // Generate example value
        var exVal = generateFieldExample(f);
        state.paramValues[paramKey] = exVal;
        // Update DOM
        var el = document.querySelector('[data-bodypath="' + childPath + '"][data-ctrl="' + ctrlIdx + '"][data-api="' + apiIdx + '"]');
        if (el) { el.value = exVal; }
      }
    }
  }

  var bpIdx = 0;
  for (var bp = 0; bp < api.parameters.length; bp++) {
    if (api.parameters[bp].location !== 'body') continue;
    if (api.parameters[bp].children && api.parameters[bp].children.length > 0) {
      walkAndFill(api.parameters[bp].children, '');
    }
    bpIdx++;
  }
  persist();
  showToast(_t('已填入示例值'));
}

function generateFieldExample(field) {
  var t = simpleType(field.javaType);
  if (t === 'String') return 'string';
  if (t === 'LocalDate') return '2025-01-01';
  if (t === 'LocalTime') return '00:00:00';
  if (isDateTimeType(t)) return '2025-01-01T00:00:00';
  if (isSimpleNumberType(t)) return '0';
  if (t === 'Boolean' || t === 'boolean') return 'false';
  return '';
}

// ===== BODY VIEW SWITCHING (form / JSON) =====
function switchBodyView(view, ctrlIdx, apiIdx) {
  var formView = document.getElementById('body-form-view');
  var jsonView = document.getElementById('body-json-view');
  var formBtn = document.getElementById('body-view-form-btn');
  var jsonBtn = document.getElementById('body-view-json-btn');
  if (!formView || !jsonView) return;

  if (view === 'json') {
    // Switch to JSON: serialize current form values to JSON
    syncFormToJson(ctrlIdx, apiIdx);
    formView.style.display = 'none';
    jsonView.style.display = 'block';
    if (formBtn) { formBtn.style.background = 'var(--bg3)'; formBtn.style.color = 'var(--text)'; }
    if (jsonBtn) { jsonBtn.style.background = 'var(--accent)'; jsonBtn.style.color = '#fff'; }
  } else {
    // Switch to form: parse JSON and fill form fields
    syncJsonToForm(ctrlIdx, apiIdx);
    jsonView.style.display = 'none';
    formView.style.display = 'block';
    if (formBtn) { formBtn.style.background = 'var(--accent)'; formBtn.style.color = '#fff'; }
    if (jsonBtn) { jsonBtn.style.background = 'var(--bg3)'; jsonBtn.style.color = 'var(--text)'; }
  }
}

// Sync form field values → JSON textarea
function syncFormToJson(ctrlIdx, apiIdx) {
  var body = buildBodyObject(ctrlIdx, apiIdx);
  var editor = document.getElementById('body-editor');
  if (editor && body) {
    editor.value = JSON.stringify(body, null, 2);
  } else if (editor && !body) {
    editor.value = '';
  }
}

// Sync JSON textarea → form field values
function syncJsonToForm(ctrlIdx, apiIdx) {
  var editor = document.getElementById('body-editor');
  if (!editor || !editor.value.trim()) return;
  try {
    var obj = JSON.parse(editor.value);
    var ctrl = state.data.controllers[ctrlIdx];
    var api = ctrl.methods[apiIdx];
    var bodyParams = api.parameters.filter(function(p){return p.location==='body';});
    if (bodyParams.length === 0) return;

    function fillFromJson(fields, jsonObj, pathPrefix) {
      if (!jsonObj || typeof jsonObj !== 'object') return;
      for (var i = 0; i < fields.length; i++) {
        var f = fields[i];
        var childPath = pathPrefix !== '' ? (pathPrefix + '_' + i) : ('' + i);
        var paramKey = 'bodyfield_' + ctrlIdx + '_' + apiIdx + '_' + childPath;
        var val = jsonObj[f.name];
        if (f.children && f.children.length > 0 && val && typeof val === 'object' && !Array.isArray(val)) {
          fillFromJson(f.children, val, childPath);
        } else if (val !== undefined && val !== null) {
          var strVal = Array.isArray(val) ? val.join(',') : (typeof val === 'object' ? JSON.stringify(val) : String(val));
          state.paramValues[paramKey] = strVal;
          var el = document.querySelector('[data-bodypath="' + childPath + '"][data-ctrl="' + ctrlIdx + '"][data-api="' + apiIdx + '"]');
          if (el) el.value = strVal;
        }
      }
    }

    var bpIdx = 0;
    for (var bp = 0; bp < api.parameters.length; bp++) {
      if (api.parameters[bp].location !== 'body') continue;
      if (api.parameters[bp].children && api.parameters[bp].children.length > 0) {
        fillFromJson(api.parameters[bp].children, obj, '');
      }
      bpIdx++;
    }
    persist();
  } catch(e) {
    // Invalid JSON — ignore, user is still typing
  }
}

// ===== HEADER TABLE RENDERING =====
function renderHeaderTable(headers, filterFn) {
  var entries = [];
  var keys = Object.keys(headers);
  for (var i = 0; i < keys.length; i++) {
    if (!filterFn || filterFn(keys[i])) {
      entries.push({key: keys[i], value: headers[keys[i]]});
    }
  }
  entries.sort(function(a,b){ return a.key.toLowerCase().localeCompare(b.key.toLowerCase()); });
  var html = '<table class="header-table">';
  for (var j = 0; j < entries.length; j++) {
    html += '<tr><td class="header-key">' + escHtml(entries[j].key) + '</td><td class="header-val">' + escHtml(entries[j].value) + '</td></tr>';
  }
  html += '</table>';
  return html;
}

function copyText(btn, text) {
  navigator.clipboard.writeText(text).then(function() {
    btn.textContent = _t('已复制!');
    setTimeout(function(){ btn.textContent = _t('复制'); }, 1500);
  });
}

function showToast(msg) {
  var existing = document.querySelector('.toast');
  if (existing) existing.remove();
  var el = document.createElement('div');
  el.className = 'toast';
  el.textContent = msg;
  document.body.appendChild(el);
  setTimeout(function(){ el.remove(); }, 2500);
}

// ===== CUSTOM HEADERS =====
function addCustomHeader(ctrlIdx, apiIdx) {
  var hdrKey = 'customHeaders_' + ctrlIdx + '_' + apiIdx;
  var headers = [];
  try { var raw = state.paramValues[hdrKey]; if (raw) headers = JSON.parse(raw); } catch(e) {}
  headers.push({key: '', val: ''});
  state.paramValues[hdrKey] = JSON.stringify(headers);
  persist();
  // Re-render detail
  selectApi(ctrlIdx, apiIdx, true);
}

function deleteCustomHeader(ctrlIdx, apiIdx, index) {
  var hdrKey = 'customHeaders_' + ctrlIdx + '_' + apiIdx;
  var headers = [];
  try { var raw = state.paramValues[hdrKey]; if (raw) headers = JSON.parse(raw); } catch(e) {}
  headers.splice(index, 1);
  state.paramValues[hdrKey] = JSON.stringify(headers);
  persist();
  selectApi(ctrlIdx, apiIdx, true);
}

function saveCustomHeaders(ctrlIdx, apiIdx) {
  var rows = document.querySelectorAll('.custom-header-row');
  var headers = [];
  for (var i = 0; i < rows.length; i++) {
    var keyEl = rows[i].querySelector('.header-key-input');
    var valEl = rows[i].querySelector('.header-val-input');
    if (keyEl && valEl) {
      headers.push({key: keyEl.value, val: valEl.value});
    }
  }
  var hdrKey = 'customHeaders_' + ctrlIdx + '_' + apiIdx;
  state.paramValues[hdrKey] = JSON.stringify(headers);
  persist();
}

// ===== SAVE WITH EDITS (export self-contained HTML) =====
function saveWithEdits() {
  try {
    var editsJson = JSON.stringify(state.edits);
    // Escape closing script tags in JSON data for safe HTML embedding
    var safeEditsJson = editsJson.replace(/<\//g, '<\\/');

    // Use the pristine HTML captured at init time (before DOM modifications).
    // This is much more reliable than re-serializing the current DOM which
    // may have been mutated by user interactions, request history, etc.
    var docHtml = window.__POSTEASY_PRISTINE_HTML__ || document.documentElement.outerHTML;

    // Build the embedded edits script — injected before </head>
    // The JSON data is safe because all </ sequences have been escaped to <\/
    // NOTE: use string concat to avoid literal closing script tag in this script block
    var scriptOpen = '\n<script>window.__EMBEDDED_EDITS__ = ' + safeEditsJson + ';';
    var scriptClose = '<' + '/script>';
    var injection = scriptOpen + scriptClose;
    // Also store in a <meta> tag as a robust fallback
    // Escape for HTML attribute: & must come first to avoid double-escaping
    var metaContent = safeEditsJson.replace(/&/g, '&amp;').replace(/"/g, '&quot;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
    var metaTag = '\n<meta name="posteasy-edits" content="' + metaContent + '">';

    var html = '<!DOCTYPE html>\n' + docHtml;
    // Insert the injection right before </head> so it takes effect before the main init
    var headEndIdx = html.indexOf('</head>');
    if (headEndIdx > 0) {
      html = html.substring(0, headEndIdx) + metaTag + injection + '\n' + html.substring(headEndIdx);
    } else {
      // Fallback: insert before </body>
      var bodyEndIdx = html.lastIndexOf('</body>');
      if (bodyEndIdx > 0) {
        html = html.substring(0, bodyEndIdx) + metaTag + injection + '\n' + html.substring(bodyEndIdx);
      }
    }

    var blob = new Blob([html], {type: 'text/html;charset=utf-8'});
    var a = document.createElement('a');
    a.href = URL.createObjectURL(blob);
    a.download = (state.data.projectName || 'API') + '-API文档(含说明).html';
    document.body.appendChild(a);
    a.click();
    document.body.removeChild(a);
    setTimeout(function() { URL.revokeObjectURL(a.href); }, 100);
    showToast(_t('已导出含说明的文档'));
  } catch(e) {
    showToast('导出失败: ' + e.message);
  }
}

// ===== INIT =====
// Load embedded edits (from a previously saved doc)
// Try inline script variable first, fallback to <meta> tag
var __embeddedEdits = window.__EMBEDDED_EDITS__;
if (!__embeddedEdits) {
  var metaEdits = document.querySelector('meta[name="posteasy-edits"]');
  if (metaEdits) {
    try {
      var metaContent = metaEdits.getAttribute('content');
      if (metaContent) {
        // Decode HTML entities from the meta content attribute
        var txt = document.createElement('textarea');
        txt.innerHTML = metaContent;
        __embeddedEdits = JSON.parse(txt.value);
      }
    } catch(e) { /* ignore meta parse errors */ }
  }
}
if (__embeddedEdits) {
  var embedded = __embeddedEdits;
  var ekeys = Object.keys(embedded);
  var loaded = 0;
  for (var ei = 0; ei < ekeys.length; ei++) {
    if (!(ekeys[ei] in state.edits)) {
      state.edits[ekeys[ei]] = embedded[ekeys[ei]];
      loaded++;
    }
  }
  if (loaded > 0) {
    persist();
    showToast(_t('已加载内嵌说明') + ' (' + loaded + ')');
  }
}

// Set up language toggle and static texts
var langBtn = document.getElementById('lang-toggle');
if (langBtn) langBtn.textContent = state.lang === 'zh' ? 'EN' : '中';
var historyBtn2 = document.getElementById('history-btn');
if (historyBtn2) historyBtn2.textContent = _t('历史记录');
var sendBtn = document.getElementById('send-btn');
if (sendBtn) sendBtn.textContent = _t('发送请求');
var htitle = document.getElementById('history-title');
if (htitle) htitle.textContent = _t('请求历史');
var searchInput2 = document.getElementById('search-input');
if (searchInput2) searchInput2.placeholder = _t('搜索接口...');
var saveEditsBtn = document.getElementById('save-edits-btn');
if (saveEditsBtn) saveEditsBtn.textContent = _t('💾 导出文档(含说明)');
// Set document title
if (state.data.projectName) {
  document.title = state.data.projectName + ' - ' + _t('API 文档');
}

// Capture pristine HTML before any DOM modifications by buildTree/selectApi.
// This is used by saveWithEdits() to produce a clean export without
// the artifacts of user interactions (modified fields, response data, etc.).
if (!window.__POSTEASY_PRISTINE_HTML__) {
  window.__POSTEASY_PRISTINE_HTML__ = document.documentElement.outerHTML;
}

buildTree();
initEnvs();

// Select first API by default
if (state.data.controllers.length > 0 && state.data.controllers[0].methods.length > 0) {
  selectApi(0, 0, true);
}
</script>
</body>
