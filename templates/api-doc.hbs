document.getElementById('search-input').addEventListener('input', function() {
  var q = this.value.toLowerCase();
  var items = document.querySelectorAll('.tree-item');
  var groups = document.querySelectorAll('.tree-group');
  var anyVisible = false;

  for (var i=0;i<items.length;i++) {
    var text = items[i].textContent.toLowerCase();
    var show = !q || text.indexOf(q) >= 0;
    items[i].style.display = show ? 'flex' : 'none';
    if (show) anyVisible = true;
  }

  // Show/hide groups
  for (var g=0;g<groups.length;g++) {
    var hasVisible = false;
    var groupItems = groups[g].querySelectorAll('.tree-item');
    for (var gi=0;gi<groupItems.length;gi++) {
      if (groupItems[gi].style.display !== 'none') { hasVisible = true; break; }
    }
    groups[g].style.display = hasVisible || !q ? '' : 'none';
    // Auto-expand groups with matches
    if (hasVisible && q) {
      var itemsDiv = groups[g].querySelector('.tree-items');
      var arrow = groups[g].querySelector('.arrow');
      if (itemsDiv) itemsDiv.classList.add('open');
      if (arrow) arrow.classList.add('open');
    }
  }

  if (!anyVisible && q) {
    // Show "no results" — handled by CSS
  }
});

